# ─── Database ────────────────────────────────────────────────────────────────
# Kết nối PostgreSQL. Khớp với cấu hình trong docker-compose.yml.
DATABASE_URL=postgresql://deplao:deplao_local@localhost:5433/deplao_web

# ─── Cache / Queue ───────────────────────────────────────────────────────────
# Kết nối Redis dùng cho session cache, job queue (BullMQ), và rate-limiting.
REDIS_URL=redis://localhost:6379

# ─── Encryption ──────────────────────────────────────────────────────────────
# Khóa 32-byte (hex 64 ký tự) dùng để mã hóa AES-256 thông tin nhạy cảm
# lưu trong database (cookie Zalo, token, v.v.).
# Generate: openssl rand -hex 32
MASTER_KEY=change_me_32_byte_hex_key_here_000000000000000000000000000000

# Khóa HMAC-SHA256 dùng để ký audit log — phát hiện nếu log bị sửa.
# Generate: openssl rand -hex 32
AUDIT_HMAC_KEY=change_me_32_byte_hex_key_here_111111111111111111111111111111

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret ký JWT trả về cho frontend sau khi đăng nhập.
# Generate: openssl rand -base64 48
JWT_SECRET=change_me_jwt_secret_here

# ─── Internal Services ───────────────────────────────────────────────────────
# Base URL của Vault service (lưu trữ credential Zalo) dùng cho giao tiếp
# nội bộ giữa các service — không expose ra ngoài internet.
VAULT_INTERNAL_URL=http://localhost:3001

# Danh sách IP (phân cách dấu phẩy) được phép gọi các endpoint nội bộ.
# Thường là IP của các container/service khác trong cùng Docker network.
INTERNAL_ALLOWED_IPS=127.0.0.1,::1

# ─── CORS ────────────────────────────────────────────────────────────────────
# Origin của frontend được phép gửi request (CORS). Dùng URL Electron app
# hoặc dev server khi phát triển.
FRONTEND_ORIGIN=http://localhost:5173
